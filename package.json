{
  "name": "ssh-tech-lander",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace apps/new-site",
    "build": "npm run build --workspace apps/new-site",
    "start": "npm run start --workspace apps/new-site",
    "lint": "npm run lint --workspace apps/new-site && npm run lint --workspace packages/brand-ui",
    "dev:legacy": "next dev",
    "build:legacy": "next build",
    "start:legacy": "next start",
    "lint:legacy": "eslint .",
    "gitleaks:scan": "gitleaks detect --source .",
    "semgrep:scan": "semgrep scan --config p/ci --metrics=off",
    "trivy:fs": "trivy fs .",
    "trivy:config": "trivy config .",
    "security:code": "npm run gitleaks:scan && npm run semgrep:scan && npm run trivy:fs && npm run trivy:config",
    "storybook": "HOME=.storybook-home STORYBOOK_DISABLE_TELEMETRY=1 CI=1 storybook dev --port 6006 --host 127.0.0.1 --ci --no-open",
    "build-storybook": "HOME=.storybook-home STORYBOOK_DISABLE_TELEMETRY=1 CI=1 storybook build",
    "visual:test": "npm run build-storybook && STORYBOOK_DISABLE_TELEMETRY=1 CI=1 playwright test --config tests/visual-regression/playwright.config.cjs",
    "visual:baseline": "npm run build-storybook && STORYBOOK_DISABLE_TELEMETRY=1 CI=1 playwright test --config tests/visual-regression/playwright.config.cjs --update-snapshots"
  },
  "dependencies": {
    "@calcom/embed-react": "^1.5.2",
    "@contentful/rich-text-react-renderer": "^16.0.1",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^5.16.14",
    "@mui/material": "^5.16.14",
    "@supabase/supabase-js": "^2.49.4",
    "clsx": "^2.1.1",
    "contentful": "^11.5.0",
    "contentful-management": "^11.47.2",
    "next": "15.5.7",
    "next-sitemap": "^4.2.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-syntax-highlighter": "^5.8.0",
    "ssh-node-logger": "^1.0.6",
    "tailwind-merge": "^3.0.2",
    "type-check": "^0.4.0"
  },
  "devDependencies": {
    "@fontsource/exo-2": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/montserrat": "^5.2.8",
    "@fontsource/play": "^5.2.8",
    "@fontsource/poppins": "^5.2.7",
    "@playwright/test": "^1.55.0",
    "@storybook/addon-a11y": "10.2.19",
    "@storybook/addon-docs": "10.2.19",
    "@storybook/addon-links": "10.2.19",
    "@storybook/nextjs": "10.2.19",
    "@types/node": "^20",
    "@types/react": "18.3.5",
    "@types/react-dom": "18.3.5",
    "eslint": "^9",
    "eslint-config-next": "15.5.7",
    "postcss": "^8",
    "storybook": "10.2.19",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  },
  "overrides": {
    "@types/react": "18.3.5",
    "@types/react-dom": "18.3.5"
  }
}
