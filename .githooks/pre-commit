#!/usr/bin/env bash
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

require_tool() {
  local tool="$1"
  if ! command -v "$tool" >/dev/null 2>&1; then
    echo "pre-commit: missing required tool: $tool"
    echo "Install it (brew) and retry."
    exit 1
  fi
}

require_tool gitleaks
require_tool semgrep

echo "pre-commit: gitleaks protect (staged)"
gitleaks protect --staged --redact

echo "pre-commit: semgrep scan (p/ci)"
semgrep scan --config p/ci --metrics=off
